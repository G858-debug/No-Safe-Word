CIVITAI_API_KEY=your_civitai_api_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Facebook Graph API (for story publishing)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# Webhook authentication (for /api/webhook/story-import)
WEBHOOK_SECRET=

# Flux Kontext model downloads (run: npm run download:kontext-models)
HF_TOKEN=                    # HuggingFace token — accept license at https://huggingface.co/black-forest-labs/FLUX.1-Kontext-dev
CIVITAI_TOKEN=               # Civitai API key — https://civitai.com/user/account
RUNPOD_NETWORK_VOLUME_ID=    # Found in RunPod dashboard > Storage > your volume ID

# Flux Kontext model filenames (set after running download:kontext-models)
KONTEXT_SFW_MODEL=flux1-dev-kontext_fp8_scaled.safetensors
KONTEXT_NSFW_MODEL=fuxCapacityNSFWPorn_51FP16.safetensors

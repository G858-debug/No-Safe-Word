CIVITAI_API_KEY=your_civitai_api_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Facebook Graph API (for story publishing)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# Webhook authentication (for /api/webhook/story-import)
WEBHOOK_SECRET=

# Flux Kontext model downloads (run: npm run download:kontext-models)
HF_TOKEN=                    # HuggingFace token — accept license at https://huggingface.co/black-forest-labs/FLUX.1-Kontext-dev
CIVITAI_TOKEN=               # Civitai API key — https://civitai.com/user/account
RUNPOD_NETWORK_VOLUME_ID=    # Found in RunPod dashboard > Storage > your volume ID

# Flux Krea Dev model filename (set after running download:kontext-models)
KONTEXT_MODEL=flux1KreaDev_fp8E4m3fn.safetensors

# V2 Scene Pipeline (NB2 → Florence-2/SAM2 → UnCanny)
# Set to 'v2' to enable the new inpainting pipeline route
SCENE_PIPELINE_VERSION=v1

# UnCanny model filename on the network volume
UNCANNY_MODEL_NAME=uncanny_v1.3_fp8.safetensors

# Chroma VAE (same ae.safetensors used by Flux — no change needed if already present)
# UNCANNY_VAE_NAME=ae.safetensors
